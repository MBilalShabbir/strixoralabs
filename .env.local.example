# ── Strixora Labs — Environment Variables ──────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Contact form email (via Resend) ─────────────────────────────────────────
# Sign up at https://resend.com — free tier is 3,000 emails/month.
# Email delivery activates automatically once this key is set.
# Without it, form submissions are logged to console (dev fallback).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@strixoralabs.com
CONTACT_EMAIL=hello@strixoralabs.com

# ── Analytics (optional) ────────────────────────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxx
