# ── Strixora Labs — Environment Variables ──────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Contact form email (via Resend) ─────────────────────────────────────────
# Sign up at https://resend.com and create an API key.
# Then uncomment the Resend block in app/api/contact/route.ts
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@strixoralabs.com
CONTACT_EMAIL=hello@strixoralabs.com

# ── Analytics (optional) ────────────────────────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxx
